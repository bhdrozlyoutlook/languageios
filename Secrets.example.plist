<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template for App/Secrets.plist (which is gitignored and never committed).

  Setup:
    1. cp Secrets.example.plist App/Secrets.plist
    2. Paste your keys into App/Secrets.plist
    3. Rebuild — AppEnvironment.live() auto-detects the key and switches the
       object recognizer / sentence analyzer to Gemini (falls back to on-device
       when a key is empty).

  Keys can also be supplied via the process environment (GEMINI_API_KEY=...),
  which takes precedence — handy for CI.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>GEMINI_API_KEY</key>
	<string></string>
	<key>ELEVENLABS_API_KEY</key>
	<string></string>
	<!-- Set this (and add the RevenueCat SPM package) to switch purchases from the
	     local fake to RevenueCat. See docs/revenuecat.md. -->
	<key>REVENUECAT_API_KEY</key>
	<string></string>
</dict>
</plist>
